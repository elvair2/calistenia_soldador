<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HUD do Soldador - Full Memory Edition</title>
    <style>
        :root {
            --bg-color: #121212;
            --panel-bg: #1e1e1e;
            --accent-color: #ff8c00;
            --rest-color: #00e5ff;
            --text-color: #e0e0e0;
            --muted-text: #a0a0a0;
        }

        body {
            background-color: var(--bg-color); color: var(--text-color);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; margin: 0; user-select: none;
        }

        .hud-container {
            background: var(--panel-bg); width: 90%; max-width: 400px;
            padding: 25px; border-radius: 12px; border: 1px solid #333;
            box-shadow: 0 0 20px rgba(255, 140, 0, 0.15); text-align: center;
            position: relative; overflow: hidden;
        }

        .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }

        .header {
            font-size: 0.9em; color: var(--accent-color);
            text-transform: uppercase; letter-spacing: 2px; font-weight: bold;
        }

        .mini-menu { display: flex; gap: 8px; }
        .mini-btn {
            background: #2a2a2a; border: 1px solid #444; color: #fff;
            border-radius: 4px; padding: 4px 8px; cursor: pointer; font-size: 0.9em;
        }
        .mini-btn:hover { background: #444; }

        .status-badge {
            display: inline-block; padding: 4px 10px; background: #333; border-radius: 4px;
            font-size: 0.8em; font-weight: bold; letter-spacing: 1px; margin-bottom: 15px;
            border: 1px solid #555;
        }

        h2 { margin: 0 0 5px 0; font-size: 1.4em; }

        .desc { font-size: 0.85em; color: var(--muted-text); margin-bottom: 15px; min-height: 35px; }

        .image-container {
            width: 100%; height: 180px; background-color: #2a2a2a; border-radius: 8px;
            margin-bottom: 15px; overflow: hidden; display: flex; justify-content: center; align-items: center;
            border: 2px solid #333; position: relative;
        }

        img { width: 100%; height: 100%; object-fit: cover; }

        .stats-row {
            display: flex; justify-content: space-between; font-size: 0.9em;
            color: var(--muted-text); margin-bottom: 10px; padding: 0 10px;
        }
        .stat-value { font-weight: bold; color: var(--text-color); font-size: 1.1em; }

        .timer {
            font-size: 4em; font-weight: bold; color: var(--accent-color);
            font-family: 'Courier New', Courier, monospace; text-shadow: 0 0 15px rgba(255, 140, 0, 0.4);
            margin: 5px 0; transition: color 0.3s, text-shadow 0.3s;
        }

        .progress-bar-container {
            width: 100%; height: 12px; background-color: #222; border-radius: 6px;
            border: 1px solid #444; margin: 15px 0 20px 0; overflow: hidden;
        }
        .progress-bar {
            height: 100%; width: 0%; background-color: var(--accent-color);
            box-shadow: 0 0 10px var(--accent-color); transition: width 1s linear;
        }

        .controls { display: flex; gap: 10px; justify-content: center; }

        .btn-main {
            flex: 1; background-color: #333; color: var(--text-color);
            border: 1px solid #555; padding: 12px; border-radius: 6px;
            font-size: 0.9em; font-weight: bold; cursor: pointer; text-transform: uppercase;
        }
        .btn-main:hover { background-color: #444; }

        #btn-action { background-color: var(--accent-color); color: #000; border: none; }
        #btn-action:hover { background-color: #e07b00; }

        .mode-rest .timer { color: var(--rest-color); text-shadow: 0 0 15px rgba(0, 229, 255, 0.4); }
        .mode-rest .progress-bar { background-color: var(--rest-color); box-shadow: 0 0 10px var(--rest-color); }
        .mode-rest .status-badge { background-color: rgba(0, 229, 255, 0.1); color: var(--rest-color); border-color: var(--rest-color); }

        .modal {
            display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(18, 18, 18, 0.95); z-index: 10; flex-direction: column;
            padding: 25px; box-sizing: border-box; text-align: left; overflow-y: auto;
        }
        .modal h3 { color: var(--accent-color); margin-top: 0; border-bottom: 1px solid #444; padding-bottom: 10px;}
        .modal h4 { color: var(--accent-color); margin: 15px 0 5px 0;}
        .modal label { display: block; margin-top: 15px; font-size: 0.85em; color: var(--muted-text); }
        .modal input[type="number"], .modal input[type="text"] { 
            width: 100%; background: #2a2a2a; border: 1px solid #555; color: #fff;
            padding: 10px; margin-top: 5px; border-radius: 4px; box-sizing: border-box; font-weight: bold;
        }
        .modal-btn-row { display: flex; gap: 10px; margin-top: 25px; padding-bottom: 20px;}

        .config-ex-item { background: #222; padding: 10px; border-radius: 6px; border: 1px solid #333; margin-bottom: 10px; }
        .config-ex-title { font-size: 0.85em; color: #ccc; margin-bottom: 5px; font-weight: bold;}
        
        input[type="file"] {
            margin-top: 8px; font-size: 0.8em; color: #ccc; background: #1a1a1a; padding: 5px; border-radius: 4px; width: 100%; box-sizing: border-box; border: 1px dashed #555;
        }

        .log-container {
            margin-top: 15px; border: 1px solid #333; border-radius: 6px;
            background: #1a1a1a; max-height: 200px; overflow-y: auto; padding: 10px;
        }
        .log-entry {
            display: flex; justify-content: space-between; padding: 8px 0;
            border-bottom: 1px dashed #333; font-family: monospace; font-size: 0.95em;
        }
        .log-entry:last-child { border-bottom: none; }
        .log-date { color: var(--muted-text); }
        .log-xp { color: var(--accent-color); font-weight: bold; }
    </style>
</head>
<body>

    <audio id="audio-work" loop></audio>
    <audio id="audio-rest" loop></audio>

    <div class="hud-container" id="hud">
        <div class="top-bar">
            <div class="header">Estamina Ocupacional</div>
            <div class="mini-menu">
                <button class="mini-btn" onclick="openStats()">📅 Log</button>
                <button class="mini-btn" onclick="openConfig()">⚙️ Level</button>
            </div>
        </div>
        
        <div class="status-badge" id="status-badge">AGUARDANDO INÍCIO</div>

        <div class="image-container">
            <img id="ex-img" src="" alt="Referência">
        </div>

        <h2 id="ex-title">Carregando...</h2>
        <div class="desc" id="ex-desc">...</div>

        <div class="stats-row">
            <div>Série: <span class="stat-value" id="set-display">1 / 3</span></div>
            <div>Skill: <span class="stat-value" id="ex-display">1 / 4</span></div>
        </div>

        <div class="timer" id="timer-display">00:00</div>

        <div class="progress-bar-container">
            <div class="progress-bar" id="p-bar"></div>
        </div>

        <div class="controls">
            <button class="btn-main" id="btn-action" onclick="toggleTimer()">INICIAR</button>
            <button class="btn-main" onclick="skip()">PULAR >></button>
        </div>

        <div class="modal" id="modal-config">
            <h3>⚙️ Customização de Habilidades</h3>
            
            <label>Tempo de Tensão (segundos)</label>
            <input type="number" id="cfg-time" value="45">
            <label>Tempo de Descanso (segundos)</label>
            <input type="number" id="cfg-rest" value="30">
            <label>Número de Séries por Posição</label>
            <input type="number" id="cfg-sets" value="3" style="margin-bottom: 15px;">

            <div style="border-top: 1px solid #444; padding-top: 10px;">
                <h4>🎵 Upload de Trilha Sonora (.mp3)</h4>
                <div style="font-size:0.75em; color:#888; margin-bottom: 10px;">Atenção: Use arquivos pequenos (MP3 curto) para não estourar a memória.</div>
                
                <label>Combate (Alto BPM)</label>
                <input type="text" id="cfg-music-work" placeholder="[Nenhum arquivo ou link]" readonly>
                <input type="file" id="up-audio-work" accept="audio/mp3,audio/mpeg" onchange="handleAudioUpload(this, 'work')">
                
                <label>Descanso (Clássica)</label>
                <input type="text" id="cfg-music-rest" placeholder="[Nenhum arquivo ou link]" readonly>
                <input type="file" id="up-audio-rest" accept="audio/mp3,audio/mpeg" onchange="handleAudioUpload(this, 'rest')">
            </div>

            <div style="border-top: 1px solid #444; padding-top: 15px; margin-top: 15px;">
                <h4>🖼️ Imagens do Inventário (Upload)</h4>
                <div id="config-exercises-list"></div>
            </div>

            <div style="border-top: 1px solid #444; padding-top: 10px; margin-top: 10px;">
                <h4>➕ Adicionar Novo Exercício</h4>
                <input type="text" id="new-ex-title" placeholder="Nome (Ex: Flexão)">
                <input type="text" id="new-ex-desc" placeholder="Descrição rápida">
                <button class="btn-main" style="margin-top: 10px; width: 100%; padding: 10px;" onclick="addCustomExercise()">ADICIONAR À LISTA</button>
            </div>

            <div class="modal-btn-row">
                <button class="btn-main" id="btn-action" onclick="saveConfig()">SALVAR TUDO</button>
                <button class="btn-main" onclick="closeModals()">FECHAR</button>
            </div>
        </div>

        <div class="modal" id="modal-stats">
            <h3>📅 Diário de Combate</h3>
            <div class="log-container" id="calendar-log"></div>
            <div class="modal-btn-row">
                <button class="btn-main" onclick="closeModals()">FECHAR</button>
            </div>
        </div>
    </div>

    <script>
        let defaultSettings = { 
            time: 45, rest: 30, sets: 3,
            musicWork: "", musicRest: ""
        };
        let playerStats = { history: {} }; 
        let tempImageUploads = {}; 
        let tempAudioUploads = { work: "", rest: "" };
        
        let workoutData = [
            { title: "A Prancha (Defesa)", desc: "Cotovelos no chão, corpo reto.", img: "https://images.unsplash.com/photo-1566241142559-40e1dab266c6?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" },
            { title: "Cadeirinha (Wall Sit)", desc: "Costas na parede, 90 graus.", img: "https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" },
            { title: "Voo do Superman", desc: "Eleve braços e pernas deitado.", img: "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" },
            { title: "Estátua da Tocha", desc: "Segure um peso e não trema.", img: "https://images.unsplash.com/photo-1581009146145-b5ef050c2e1e?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" }
        ];

        try {
            let s = localStorage.getItem('soldador_cfg'); if(s) defaultSettings = JSON.parse(s);
            let st = localStorage.getItem('soldador_stats'); if(st) playerStats = JSON.parse(st);
            let w = localStorage.getItem('soldador_workout'); if(w) workoutData = JSON.parse(w);
        } catch(e) {}

        const audioWork = document.getElementById('audio-work');
        const audioRest = document.getElementById('audio-rest');
        let fadeInterval = null;

        function crossfade(audioOut, audioIn) {
            clearInterval(fadeInterval);
            if (!audioIn.src) return;
            audioIn.volume = 0;
            audioIn.play().catch(()=>{});
            let vol = 0;
            fadeInterval = setInterval(() => {
                vol += 0.05;
                if (vol >= 1) { vol = 1; clearInterval(fadeInterval); audioOut.pause(); }
                audioIn.volume = vol;
                audioOut.volume = Math.max(0, 1 - vol);
            }, 100);
        }

        function updateAudioEngine(forcePause = false) {
            if (audioWork.src !== defaultSettings.musicWork) audioWork.src = defaultSettings.musicWork;
            if (audioRest.src !== defaultSettings.musicRest) audioRest.src = defaultSettings.musicRest;

            if (forcePause || !isRunning) {
                audioWork.pause(); audioRest.pause(); return;
            }

            if (isResting) {
                if (audioWork.duration > 0 && !audioWork.paused) crossfade(audioWork, audioRest);
                else { audioRest.volume = 1; audioRest.play().catch(()=>{}); }
            } else {
                if (audioRest.duration > 0 && !audioRest.paused) crossfade(audioRest, audioWork);
                else { audioWork.volume = 1; audioWork.play().catch(()=>{}); }
            }
        }

        let exIndex = 0, currentSet = 1, isResting = false, timeLeft = 0, totalTimeForPhase = 0, timerInterval = null, isRunning = false, sessionXP = 0; 

        const elTitle = document.getElementById('ex-title'), elDesc = document.getElementById('ex-desc'), elTimer = document.getElementById('timer-display'), elImg = document.getElementById('ex-img'), btnAction = document.getElementById('btn-action'), elSetDisplay = document.getElementById('set-display'), elExDisplay = document.getElementById('ex-display'), elPBar = document.getElementById('p-bar'), elStatus = document.getElementById('status-badge');

        function loadExercise(index) {
            clearInterval(timerInterval); isRunning = false; exIndex = index; currentSet = 1; isResting = false;
            updateAudioEngine(true);
            if(index >= workoutData.length) index = 0;
            const ex = workoutData[index];
            elTitle.innerText = ex.title; elDesc.innerText = ex.desc; elImg.src = ex.img;
            elExDisplay.innerText = `${index + 1} / ${workoutData.length}`;
            setupPhase();
            btnAction.innerText = "INICIAR"; elStatus.innerText = "AGUARDANDO INÍCIO";
            document.getElementById('hud').className = "hud-container"; elPBar.style.width = "0%";
        }

        function setupPhase() {
            elSetDisplay.innerText = `${currentSet} / ${defaultSettings.sets}`;
            if (isResting) {
                timeLeft = defaultSettings.rest; totalTimeForPhase = defaultSettings.rest;
                elStatus.innerText = "REGENERANDO ESTAMINA..."; document.getElementById('hud').className = "hud-container mode-rest";
            } else {
                timeLeft = defaultSettings.time; totalTimeForPhase = defaultSettings.time;
                if(isRunning) elStatus.innerText = "EM COMBATE (CONTRAINDO)";
                document.getElementById('hud').className = "hud-container";
            }
            updateTimerDisplay(); updateBar();
        }

        function updateTimerDisplay() {
            let m = Math.floor(timeLeft / 60), s = timeLeft % 60;
            elTimer.innerText = (m < 10 ? "0" + m : m) + ":" + (s < 10 ? "0" + s : s);
        }

        function updateBar() { elPBar.style.width = (((totalTimeForPhase - timeLeft) / totalTimeForPhase) * 100) + "%"; }

        function toggleTimer() {
            if (isRunning) {
                clearInterval(timerInterval); isRunning = false;
                btnAction.innerText = "RETOMAR"; elStatus.innerText = "JOGO PAUSADO";
                updateAudioEngine(true);
            } else {
                isRunning = true; btnAction.innerText = "PAUSAR";
                updateAudioEngine(false); 
                timerInterval = setInterval(() => {
                    timeLeft--;
                    if(!isResting) sessionXP++; 
                    updateTimerDisplay(); updateBar();
                    if (timeLeft <= 0) handlePhaseEnd();
                }, 1000);
            }
        }

        function handlePhaseEnd() {
            clearInterval(timerInterval); isRunning = false; 
            if (!isResting) {
                if (currentSet >= defaultSettings.sets) {
                    exIndex++; if (exIndex >= workoutData.length) finishSession(); else loadExercise(exIndex);
                } else { isResting = true; setupPhase(); toggleTimer(); }
            } else { isResting = false; currentSet++; setupPhase(); toggleTimer(); }
        }

        function finishSession() {
            let today = new Date().toLocaleDateString('pt-BR');
            playerStats.history[today] = (playerStats.history[today] || 0) + sessionXP;
            try { localStorage.setItem('soldador_stats', JSON.stringify(playerStats)); } catch(e) {}
            alert("MISSÃO CUMPRIDA!"); sessionXP = 0; loadExercise(0);
        }

        function skip() { exIndex++; if (exIndex >= workoutData.length) finishSession(); else loadExercise(exIndex); }

        function handleImageUpload(input, index) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const img = new Image();
                img.onload = function() {
                    const canvas = document.createElement('canvas');
                    const MAX_WIDTH = 400; const scale = MAX_WIDTH / img.width;
                    canvas.width = MAX_WIDTH; canvas.height = img.height * scale;
                    const ctx = canvas.getContext('2d'); ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                    tempImageUploads[index] = canvas.toDataURL('image/jpeg', 0.7);
                    document.getElementById(`cfg-link-${index}`).value = "[Imagem na Memória]";
                }
                img.src = e.target.result;
            }
            reader.readAsDataURL(input.files[0]);
        }

        function handleAudioUpload(input, type) {
            const file = input.files[0];
            if (file.size > 4000000) { alert("Arquivo muito grande! Use um MP3 de até 4MB."); return; }
            const reader = new FileReader();
            reader.onload = function(e) {
                tempAudioUploads[type] = e.target.result;
                document.getElementById(`cfg-music-${type}`).value = "[Áudio na Memória]";
            }
            reader.readAsDataURL(file);
        }

        function openConfig() {
            document.getElementById('cfg-time').value = defaultSettings.time;
            document.getElementById('cfg-rest').value = defaultSettings.rest;
            document.getElementById('cfg-sets').value = defaultSettings.sets;
            document.getElementById('cfg-music-work').value = defaultSettings.musicWork ? "[Áudio na Memória]" : "";
            document.getElementById('cfg-music-rest').value = defaultSettings.musicRest ? "[Áudio na Memória]" : "";
            const list = document.getElementById('config-exercises-list'); list.innerHTML = '';
            workoutData.forEach((ex, index) => {
                list.innerHTML += `<div class="config-ex-item">
                    <div class="config-ex-title">${ex.title}</div>
                    <input type="text" id="cfg-link-${index}" value="${ex.img.length > 200 ? '[Imagem na Memória]' : ex.img}" readonly>
                    <input type="file" accept="image/*" onchange="handleImageUpload(this, ${index})">
                </div>`;
            });
            document.getElementById('modal-config').style.display = 'flex';
        }

        function saveConfig() {
            defaultSettings.time = parseInt(document.getElementById('cfg-time').value);
            defaultSettings.rest = parseInt(document.getElementById('cfg-rest').value);
            defaultSettings.sets = parseInt(document.getElementById('cfg-sets').value);
            if (tempAudioUploads.work) defaultSettings.musicWork = tempAudioUploads.work;
            if (tempAudioUploads.rest) defaultSettings.musicRest = tempAudioUploads.rest;
            workoutData.forEach((ex, index) => { if (tempImageUploads[index]) ex.img = tempImageUploads[index]; });
            try { 
                localStorage.setItem('soldador_cfg', JSON.stringify(defaultSettings)); 
                localStorage.setItem('soldador_workout', JSON.stringify(workoutData));
            } catch(e) { alert("Erro: Memória cheia! Tente áudios menores."); }
            closeModals(); loadExercise(exIndex);
        }

        function addCustomExercise() {
            const t = prompt("Nome do exercício:"); if(!t) return;
            workoutData.push({ title: t, desc: "Personalizado", img: "https://images.unsplash.com/photo-1581009146145-b5ef050c2e1e?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" });
            openConfig();
        }

        function openStats() {
            const log = document.getElementById('calendar-log'); log.innerHTML = '';
            Object.entries(playerStats.history).forEach(([d, s]) => {
                log.innerHTML += `<div class="log-entry"><span>${d}</span><b>${Math.floor(s/60)} Min</b></div>`;
            });
            document.getElementById('modal-stats').style.display = 'flex';
        }

        function closeModals() { document.querySelectorAll('.modal').forEach(m => m.style.display = 'none'); }
        window.onload = () => loadExercise(0);
    </script>
</body>
</html>
